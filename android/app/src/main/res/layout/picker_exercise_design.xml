<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paper">

    <include
        android:id="@+id/include_top_bar"
        layout="@layout/view_top_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/tv_exercise_kicker"
            style="@style/TextKicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target muscle" />

        <TextView
            style="@style/TextH1Serif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/picker_exercise_header" />
    </LinearLayout>

    <!-- Inline muscle chip row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_muscle_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Search box -->
    <LinearLayout
        android:id="@+id/layout_search_wrap"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/shape_search_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Type to search…"
            android:textColorHint="@color/ink_3"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            app:tint="@color/ink_3" />
    </LinearLayout>

    <!-- Empty state / prompt when no muscle selected -->
    <TextView
        android:id="@+id/tv_prompt"
        style="@style/TextMuted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Pick a muscle to see exercises." />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layout_exercises_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tv_no_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="20dp"
                android:gravity="center"
                android:text="No exercises match."
                android:textSize="13sp"
                android:textColor="@color/ink_3"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
